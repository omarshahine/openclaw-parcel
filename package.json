{
  "name": "openclaw-parcel",
  "version": "2.0.6",
  "description": "OpenClaw plugin for Parcel package delivery tracking",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.23"
    },
    "build": {
      "openclawVersion": "2026.4.15"
    }
  },
  "files": [
    "dist/",
    "lib/",
    "marketplace.json",
    "openclaw.plugin.json",
    "skills/",
    "src/"
  ],
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "parcel",
    "package-tracking",
    "delivery",
    "shipping"
  ],
  "author": {
    "name": "Omar Shahine",
    "email": "omar@shahine.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/omarshahine/openclaw-parcel.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "openclaw": "^2026.3.23"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "tsup": "^8.5.0"
  },
  "scripts": {
    "plugin:check": "npx --yes @openclaw/plugin-inspector inspect --no-openclaw",
    "plugin:ci": "npx --yes @openclaw/plugin-inspector ci --no-openclaw --runtime --mock-sdk --allow-execute",
    "build": "tsup src/index.ts --format esm --out-dir dist --dts --clean --target node20"
  },
  "main": "./dist/index.js"
}
