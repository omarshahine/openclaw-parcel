  "author": {
    "name": "Omar Shahine",
    "email": "omar@shahine.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/omarshahine/openclaw-parcel.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
